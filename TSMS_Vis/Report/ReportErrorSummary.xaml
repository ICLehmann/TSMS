<UserControl x:Class="TSMS_Vis.Report.ReportErrorSummary"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TSMS_Vis.Report"
             xmlns:res="clr-namespace:TSMS_Vis.Resources"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>
        <Label Margin="0,20,0,0" Padding="2" FontSize="12" FontWeight="Bold" HorizontalContentAlignment="Center" Background="LightGray" Content="{x:Static res:ReportRes.ERRORSUMMARY}"/>
        <ListView x:Name="lvErrorSummary">
            <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}">
                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                    <Setter Property="Foreground" Value="Black"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="" Width="200" DisplayMemberBinding="{Binding Name}" />
                    <GridViewColumn Header="{x:Static res:ReportRes.PIECESSHORT}" Width="70" DisplayMemberBinding="{Binding Num}" />
                    <GridViewColumn Header="%" Width="70" DisplayMemberBinding="{Binding Percent}" />
                </GridView>
            </ListView.View>
        </ListView>
    </StackPanel>
</UserControl>
