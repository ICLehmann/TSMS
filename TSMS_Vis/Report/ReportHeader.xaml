<UserControl x:Class="TSMS_Vis.Report.ReportHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TSMS_Vis.Report"
             xmlns:res="clr-namespace:TSMS_Vis.Resources"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Height="60" VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Margin="10" Stretch="Uniform" Source="../Images/TDKLogo1.png" HorizontalAlignment="Left"/>
            <Label Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Bottom" FontSize="20" FontWeight="Bold" Content="{x:Static res:ReportRes.REPORTTITLE}"/>
            <Label Grid.Column="2" x:Name="lPage" Content="{x:Static res:ReportRes.PAGESAMPLE}"  HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        </Grid>
        <StackPanel Grid.Row="1" >
            <Rectangle HorizontalAlignment="Stretch" Fill="Black" Height="2"/>
            <StackPanel Orientation="Horizontal">
                <Label FontSize="16" FontWeight="Bold" Content="{x:Static res:ReportRes.REPORTSUBTITLE}"/>
                <Label x:Name="lWarning" FontSize="12" FontWeight="Bold" Foreground="Red" Margin="20,0,0,0" Content="{x:Static res:ReportRes.ERRORRATEWARNING}"/>
            </StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" >
                    <Label Padding="5, 2, 5, 0" Content="{x:Static res:ReportRes.MACHINENUMBER}"/>
                    <Label Padding="5, 2, 5, 0" Content="{x:Static res:ReportRes.PARTNUMBER}"/>
                    <Label Padding="5, 2, 5, 0" Content="{x:Static res:ReportRes.LOTNUMBER}"/>
                    <Label Padding="5, 2, 5, 0" Content="{x:Static res:ReportRes.LINEID}"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <Label x:Name="lMachine" Padding="5, 2, 5, 0" Content="xxxxx"  HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                    <Label x:Name="lPartNo"  Padding="5, 2, 5, 0" Content="xxxxx"  HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                    <Label x:Name="lLotNo"  Padding="5, 2, 5, 0" Content="xxxxx"  HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                    <Label x:Name="lLine"  Padding="5, 2, 5, 0" Content="xxxxx"  HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <Label Padding="5, 2, 5, 0" HorizontalAlignment="Right" Content="{x:Static res:ReportRes.STARTDATE}"/>
                    <Label Padding="5, 2, 5, 0" HorizontalAlignment="Right" Content="{x:Static res:ReportRes.ENDDATE}"/>
                    <Label Padding="5, 2, 5, 0" HorizontalAlignment="Right" Content="{x:Static res:ReportRes.STATE}"/>
                    <Label Padding="5, 2, 5, 0" HorizontalAlignment="Right" Content="{x:Static res:ReportRes.REPORTDATA}"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <Label x:Name="lStartTime" Padding="5, 2, 5, 0"  Content="xxxxx"  HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                    <Label x:Name="lEndTime" Padding="5, 2, 5, 0" Content="xxxxx"  HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                    <Label x:Name="lStatus" Padding="5, 2, 5, 0" Content="xxxxx"  HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                    <Label x:Name="lReportData" Padding="5, 2, 5, 0" Content="xxxxx"  HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
