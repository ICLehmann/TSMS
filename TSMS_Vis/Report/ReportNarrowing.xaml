<UserControl x:Class="TSMS_Vis.Report.ReportNarrowing"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:res="clr-namespace:TSMS_Vis.Resources"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="750">

    <StackPanel>
        <Label Margin="0,20,0,0" Padding="2" FontSize="12" FontWeight="Bold" HorizontalContentAlignment="Center" Background="LightGray" Content="{x:Static res:ReportRes.NARROWING}"/>
        <ListView x:Name="lvPATTable">
            <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}">
                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                    <Setter Property="Foreground" Value="Black"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="{x:Static res:ReportRes.MEASUREMENT}" Width="80" DisplayMemberBinding="{Binding Name}" />
                    <GridViewColumn Header="{x:Static res:ReportRes.UNIT}" Width="50" DisplayMemberBinding="{Binding Unit}" />
                    <GridViewColumn Header="{x:Static res:ReportRes.LOWERLIMIT}" Width="80" DisplayMemberBinding="{Binding MinLimit, StringFormat=N4}" />
                    <GridViewColumn Header="{x:Static res:ReportRes.UPPERLIMIT}" Width="80" DisplayMemberBinding="{Binding MaxLimit, StringFormat=N4}" />
                </GridView>
            </ListView.View>
        </ListView>
        <StackPanel Orientation="Horizontal">
            <Label Content="{x:Static res:ReportRes.NARROWINGMETHOD}" FontSize="10" FontWeight="Bold" Padding="5,5,5,5" ScrollViewer.CanContentScroll="True" UseLayoutRounding="True"/>
            <Label x:Name="PAT_Mode_Label" Content="{x:Static res:ReportRes.NARROWINGMETHODDATA}" FontSize="10"/>
        </StackPanel>
    </StackPanel>
</UserControl>
