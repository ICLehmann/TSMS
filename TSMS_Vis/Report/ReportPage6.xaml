<Window x:Class="TSMS_Vis.Report.ReportPage6"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TSMS_Vis.Report"
      xmlns:uc="clr-namespace:TSMS_Vis.UserControls"
      xmlns:res="clr-namespace:TSMS_Vis.Resources"
      mc:Ignorable="d" 
      d:DesignHeight="1122" d:DesignWidth="793"
      Title="PrintVisualPage1"
        Height="1122" Width="793" ShowInTaskbar="False" ResizeMode="NoResize" WindowStyle="None">

    <Grid Margin="60,30,40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <local:ReportHeader Grid.Row="0" x:Name="Header"/>
        <StackPanel Grid.Row="1" >
            <Label Margin="0,20,0,0" Padding="2" FontSize="12" FontWeight="Bold" HorizontalContentAlignment="Center" Background="LightGray" Content="{x:Static res:ReportRes.PROBABILITY}" />
            <uc:UC_Probability x:Name= "Probability1" Grid.Column="0" Height="400" Width="500"/>
            <uc:UC_Probability x:Name= "Probability2" Grid.Column="1" Height="400" Width="500"/>
        </StackPanel>
    </Grid>
</Window>
