<UserControl x:Class="TSMS_Vis.Report.ReportNarrowingSections"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:res="clr-namespace:TSMS_Vis.Resources"
             xmlns:conv="clr-namespace:TSMS_Vis.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="750">

    <StackPanel>
        <StackPanel.Resources>
            <conv:EndProduct_toReportString x:Key="endproduct_toReportString"/>
            <conv:PATMode_toReport_String x:Key="patmode_toReport_String"/>
        </StackPanel.Resources>
        <Label Margin="0,20,0,0" Padding="2" FontSize="12" FontWeight="Bold" HorizontalContentAlignment="Center" Background="LightGray" Content="{x:Static res:ReportRes.NARROWING_SECTIONS}"/>
        <ListView x:Name="lvPATTable">
            <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}">
                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                    <Setter Property="Foreground" Value="Black"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="{x:Static res:ReportRes.NARROWING_STARTPROD}" Width="120" DisplayMemberBinding="{Binding StartPart}" />
                    <GridViewColumn Header="{x:Static res:ReportRes.NARROWING_ENDPROD}" Width="120" DisplayMemberBinding="{Binding EndPart, Converter={StaticResource endproduct_toReportString}}" />
                    <GridViewColumn Header="{x:Static res:ReportRes.NARROWING_MODE}" Width="160" DisplayMemberBinding="{Binding Mode,Converter={StaticResource patmode_toReport_String}}" />
                    <GridViewColumn Header="{x:Static res:ReportRes.NARROWING_SAMPLECNT}" Width="120" DisplayMemberBinding="{Binding SampleCnt}" />
                    <GridViewColumn Header="{x:Static res:ReportRes.NARROWING_LL_SIGMA}" Width="80" DisplayMemberBinding="{Binding LL_Sigma}" />
                    <GridViewColumn Header="{x:Static res:ReportRes.NARROWING_UL_SIGMA}" Width="80" DisplayMemberBinding="{Binding UL_Sigma}" />
                </GridView>
            </ListView.View>
        </ListView>
    </StackPanel>
</UserControl>
