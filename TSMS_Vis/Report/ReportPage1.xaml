<Window x:Class="TSMS_Vis.Report.ReportPage1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TSMS_Vis.Report"
      xmlns:res="clr-namespace:TSMS_Vis.Resources"
      mc:Ignorable="d" 
        d:DesignHeight="1122" d:DesignWidth="793"
      Title="PrintVisualPage1"
        Height="1122" Width="793" ResizeMode="NoResize" ShowInTaskbar="False" WindowStyle="None">

    <Grid Margin="60,30,40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <local:ReportHeader Grid.Row="0" x:Name="Header"/>
        <StackPanel Grid.Row="1" >
            <local:ReportMeasTable x:Name="MeasTable"/>
            <local:ReportNarrowing x:Name="Narrowing"/>
            <local:ReportNarrowingSections x:Name="NarrowingSections"/>
            <local:ReportErrorSummary x:Name="ErrorSummary" HorizontalAlignment="Left"/>
        </StackPanel>
    </Grid>
</Window>
