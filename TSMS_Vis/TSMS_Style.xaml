<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- TSMS Colors -->
    <SolidColorBrush x:Key="gray" Color="#808486"/>
    <SolidColorBrush x:Key="white" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="darkgray" Color="#5C5C5C"/>
    <SolidColorBrush x:Key="lightgray" Color="#D7D7D7"/>
    <SolidColorBrush x:Key="blue" Color="#066BB3"/>
    <SolidColorBrush x:Key="red" Color="#E30613"/>
    <SolidColorBrush x:Key="green" Color="#39A935"/>
    <SolidColorBrush x:Key="yellow" Color="#FFDE00"/>
    <SolidColorBrush x:Key="pink" Color="#ED1E79"/>

    <Style TargetType="{x:Type Control}" x:Key="baseStyle">
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource baseStyle}"></Style>
    <Style TargetType="{x:Type Label}" BasedOn="{StaticResource baseStyle}"></Style>
    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource baseStyle}">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Background" Value="{StaticResource lightgray}"/>
    </Style>
    <Style TargetType="{x:Type ListView}" BasedOn="{StaticResource baseStyle}">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>
    <Style TargetType="{x:Type TabControl}" BasedOn="{StaticResource baseStyle}"></Style>
    <Style TargetType="{x:Type Menu}" BasedOn="{StaticResource baseStyle}"></Style>
    <!-- ComboBox, RadioButton, CheckBox, etc... -->

    <!-- LED control templates replaced with styles because the user could change the state of the LEDs
    In the style, the user activity is disabled with the IsEnabled property-->
        
    <Style x:Key="LEDbase" TargetType="{x:Type CheckBox}">
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="false">
                <Setter Property="Background" Value="Gray"/>
            </Trigger>
        </Style.Triggers>
        <Setter Property="IsEnabled" Value="False"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Grid>
                        <Ellipse Width="12" Height="12" Fill="{StaticResource lightgray}" />
                        <Ellipse x:Name="innen" Width="10" Height="10" Fill="{TemplateBinding Background}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GreenLED" TargetType="{x:Type CheckBox}" BasedOn="{StaticResource LEDbase}">
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="true">
                <Setter Property="Background" Value="{StaticResource green}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="YellowLED" TargetType="{x:Type CheckBox}" BasedOn="{StaticResource LEDbase}">
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="true">
                <Setter Property="Background" Value="{StaticResource yellow}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="RedLED" TargetType="{x:Type CheckBox}" BasedOn="{StaticResource LEDbase}">
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="true">
                <Setter Property="Background" Value="{StaticResource red}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>