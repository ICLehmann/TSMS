<Window x:Class="TSMS_Vis.PrintReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:res="clr-namespace:TSMS_Vis.Resources"
        mc:Ignorable="d"
        Title="{x:Static res:Resource.TITLE_PRINT_REPORT}" Height="687" SizeToContent="Width" ResizeMode="NoResize" ShowInTaskbar="False" WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow">

    <Grid Margin="10">
        <Grid.Resources>
            <!-- Default settings for controls -->
            <Style TargetType="{x:Type Label}">
                <Setter Property="Margin" Value="0,3,5,5" />
                <Setter Property="Padding" Value="0,0,0,5" />

            </Style>
            <Style TargetType="{x:Type TextBox}">
                <Setter Property="Margin" Value="0,0,0,5" />
            </Style>
            <Style TargetType="{x:Type Button}">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Padding" Value="20,0,20,0" />
                <Setter Property="Height" Value="25" />
                <Setter Property="Margin" Value="5,0,0,0" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" />
            <RowDefinition Height="35" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <StackPanel Margin="3">
                <Label Content="{x:Static res:Resource.START_DATE}" Height="Auto"/>
                <DatePicker x:Name="dtStart" Height="30"/>
            </StackPanel>
            <StackPanel Margin="3">
                <Label Content="{x:Static res:Resource.END_DATE}"/>
                <DatePicker x:Name="dtEnd" Height="30"/>
            </StackPanel>
            <StackPanel Margin="3">
                <Label Content="{x:Static res:Resource.REP_LOT_START}"/>
                <TextBox x:Name="txtLOT_Filter" Width="100" Height="30"/>
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <CheckBox x:Name="chkQueryFinishedLOTsOnly" Content="{x:Static res:Resource.REP_QUERY_FINISHED_LOTS}" VerticalAlignment="Center"/>
            <Button x:Name="btnQueryLOTs" Content="{x:Static res:Resource.REP_QUERY_LOT}" Margin="20,0,0,0" Click="btnQueryLOTs_Click"/>
        </StackPanel>
        <ListView x:Name="lvLabelToPrint" Grid.Row="2" Margin="0,10,0,10" IsEnabled="True" SelectionChanged="lvLabelToPrint_SelectionChanged">
            <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}">
                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                    <Setter Property="Margin" Value="2"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="{x:Static res:Resource.LOT}" Width="80" DisplayMemberBinding="{Binding LotNr}" />
                    <GridViewColumn Header="{x:Static res:Resource.PRODUCT}" Width="120" DisplayMemberBinding="{Binding ProductNum}" />
                    <GridViewColumn Header="{x:Static res:Resource.LINE}" Width="50" DisplayMemberBinding="{Binding LineId}" />
                    <GridViewColumn Header="{x:Static res:Resource.STATUS}" Width="80" DisplayMemberBinding="{Binding Status}" />
                    <GridViewColumn Header="{x:Static res:Resource.START_TIME}" Width="140" DisplayMemberBinding="{Binding StartTime}" />
                </GridView>
            </ListView.View>
        </ListView>
        <Grid Grid.Row="3" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="wodiButton" Content="Wodi Export" IsDefault="True" IsEnabled="False" HorizontalAlignment="Left" Click="wodiButton_Click"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="printButton" Content="{x:Static res:Resource.BTN_PRINT}" Click="printButton_Click" IsDefault="True" IsEnabled="False"/>
                <Button x:Name="closeButton" Content="{x:Static res:Resource.BTN_CLOSE}" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
