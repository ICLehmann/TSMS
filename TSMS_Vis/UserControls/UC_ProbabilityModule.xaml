<UserControl x:Class="TSMS_Vis.UserControls.UC_ProbabilityModule"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:TSMS_Vis.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="450">
    <UserControl.Resources>
        <ResourceDictionary Source="../TSMS_Style.xaml"/>
    </UserControl.Resources>

    <Border BorderBrush="{StaticResource gray}" BorderThickness="2" Margin="5">
        <Grid Background="{StaticResource white}">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="5,5,5,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" x:Name="comboBox" Width="100" HorizontalAlignment="Left" VerticalContentAlignment="Center" FontWeight="Bold" SelectionChanged="OnSelectionChanged"/>
            </Grid>
            <local:UC_Probability x:Name="prob" Grid.Row="1"/>
        </Grid>
    </Border>
</UserControl>
