<UserControl x:Class="TSMS_Vis.UserControls.UC_Probability"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:wf="clr-namespace:System.Windows.Forms.DataVisualization.Charting;assembly=System.Windows.Forms.DataVisualization"
             xmlns:local="clr-namespace:TSMS_Vis.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="450">
 
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label x:Name="lTitle" Grid.Row="0" Content="" HorizontalAlignment="Center"/>
        <WindowsFormsHost Grid.Row="1" Margin="5, 0, 5, 5">
            <wf:Chart x:Name="chart1" >
                <wf:Chart.ChartAreas>
                    <wf:ChartArea/>
                </wf:Chart.ChartAreas>
                <wf:Chart.Series>
                    <wf:Series/>
                    <wf:Series x:Name="series24" ChartType="FastLine" Color="Blue"/>
                    <wf:Series x:Name="series25" ChartType="FastLine" Color="Gold"/>
                    <wf:Series x:Name="series26" ChartType="FastLine" Color="Gold"/>
                    <wf:Series x:Name="series27" ChartType="FastLine" Color="DodgerBlue"/>
                    <wf:Series x:Name="series28" ChartType="FastLine" Color="DodgerBlue"/>
                </wf:Chart.Series>
            </wf:Chart>
        </WindowsFormsHost>
    </Grid>
</UserControl>
