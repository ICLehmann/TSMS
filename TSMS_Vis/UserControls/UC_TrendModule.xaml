<UserControl x:Class="TSMS_Vis.UserControls.UC_TrendModule"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:wf="clr-namespace:System.Windows.Forms.DataVisualization.Charting;assembly=System.Windows.Forms.DataVisualization"
             xmlns:local="clr-namespace:TSMS_Vis.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="450">

    <UserControl.Resources>
        <ResourceDictionary Source="../TSMS_Style.xaml"/>
    </UserControl.Resources>

    <Border BorderBrush="{StaticResource gray}" BorderThickness="2" Margin="5">
        <Grid Background="{StaticResource white}">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="5,5,5,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" x:Name="comboBox" Width="100" HorizontalAlignment="Left" VerticalContentAlignment="Center" FontWeight="Bold" SelectionChanged="OnSelectionChanged"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5,-5,0,0">
                    <Label Content="Min:" x:Name="lMinY"/>
                    <Label Content="Max:" x:Name="lMaxY"/>
                </StackPanel>
            </Grid>
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5,0,5,0">
                <TextBox x:Name="textBox" Width="125" TextAlignment="Right" VerticalContentAlignment="Center" IsReadOnly="True" />
                <Label Content="Ω" x:Name="lUnit" FontWeight="Bold"/>
            </StackPanel>
            <WindowsFormsHost Grid.Row="2" Margin="5, 0, 5, 5">
                <wf:Chart x:Name="chart1" >
                    <wf:Chart.Series>
                        <wf:Series/>
                        <wf:Series/>
                        <wf:Series/>
                    </wf:Chart.Series>
                    <wf:Chart.ChartAreas>
                        <wf:ChartArea/>
                    </wf:Chart.ChartAreas>
                </wf:Chart>
            </WindowsFormsHost>
        </Grid>
    </Border>
</UserControl>
