<UserControl x:Class="TSMS_Vis.UserControls.UC_CounterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TSMS_Vis.UserControls"
             xmlns:res="clr-namespace:TSMS_Vis.Resources"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="520">
    <Grid>
        <StackPanel Orientation="Horizontal">
            <StackPanel HorizontalAlignment="Left" Orientation="Vertical">
                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"  Height="25"  Margin="10,10,10,5">
                    <Label Content="{x:Static res:Resource.TOTAL}" />
                    <TextBox x:Name="tbTotal" Width="65" TextAlignment="Right" VerticalContentAlignment="Center" HorizontalAlignment="Center" IsReadOnly="True" />
                </WrapPanel>
                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Height="25" Margin="10,5,10,5">
                    <Label Content="{x:Static res:Resource.GOOD}" />
                    <TextBox x:Name="tbGood" Width="65" TextAlignment="Right" VerticalContentAlignment="Center" HorizontalAlignment="Center" IsReadOnly="True" />
                </WrapPanel>
            </StackPanel>
            <ListView x:Name="lvCounters" Margin="10" IsEnabled="False">
                <ListView.ItemContainerStyle>
                    <Style TargetType="{x:Type ListViewItem}">
                        <Setter Property="HorizontalContentAlignment" Value="Right" />
                        <Setter Property="Margin" Value="3"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="{x:Static res:Resource.COUNTER_NAME}" Width="60" DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn Header="{x:Static res:Resource.COUNTER_TOTAL}" Width="60" DisplayMemberBinding="{Binding Total}" />
                        <GridViewColumn Header="{x:Static res:Resource.COUNTER_PASS}" Width="60" DisplayMemberBinding="{Binding Pass}" />
                        <GridViewColumn Header="{x:Static res:Resource.COUNTER_LOW}" Width="60" DisplayMemberBinding="{Binding Low}" />
                        <GridViewColumn Header="{x:Static res:Resource.COUNTER_HIGH}" Width="60" DisplayMemberBinding="{Binding High}" />
                        <GridViewColumn Header="{x:Static res:Resource.COUNTER_FAIL}" Width="60" DisplayMemberBinding="{Binding Fail}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>
    </Grid>
</UserControl>
