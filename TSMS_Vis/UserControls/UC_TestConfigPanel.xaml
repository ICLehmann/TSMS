<UserControl x:Class="TSMS_Vis.UserControls.UC_TestConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TSMS_Vis.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="800">
    
    <Grid>
        <StackPanel>
            <ListView x:Name="lvConfig">
                <ListView.ItemContainerStyle>
                    <Style TargetType="{x:Type ListViewItem}">
                        <Setter Property="HorizontalContentAlignment" Value="Right" />
                        <Setter Property="Margin" Value="5"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Measurement" Width="100" DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn Header="Unit" Width="50" DisplayMemberBinding="{Binding Unit}" />
                        <GridViewColumn Header="Min" Width="75" DisplayMemberBinding="{Binding Min}" />
                        <GridViewColumn Header="PAT Min" Width="75" DisplayMemberBinding="{Binding PAT_Min, StringFormat=N4}" />
                        <GridViewColumn Header="Nom" Width="75" DisplayMemberBinding="{Binding Nom}" />
                        <GridViewColumn Header="PAT Max" Width="75" DisplayMemberBinding="{Binding PAT_Max, StringFormat=N4}" />
                        <GridViewColumn Header="Max" Width="75" DisplayMemberBinding="{Binding Max}" />
                        <GridViewColumn Header="Offset" Width="75" DisplayMemberBinding="{Binding Offset}" />
                        <GridViewColumn Header="ErrorRate" Width="75" DisplayMemberBinding="{Binding ErrorRate}" />
                        <GridViewColumn Header="Frequency" Width="75" DisplayMemberBinding="{Binding Frequency}" />
                        <GridViewColumn Header="Voltage" Width="75" DisplayMemberBinding="{Binding Voltage}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>
    </Grid>
</UserControl>
